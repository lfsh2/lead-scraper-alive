{
    "name": "business-scrape-tool",
    "version": "1.0.0",
    "description": "Tool untuk scraping nomor bisnis tanpa website untuk B2B lead generation",
    "main": "index.js",
    "scripts": {
        "setup": "node src/setup.js",
        "campaign": "node src/campaign.js",
        "start": "node src/web/server.js",
        "cli": "node index.js",
        "dev": "nodemon src/web/server.js",
        "web": "node src/web/server.js",
        "web:dev": "nodemon src/web/server.js",
        "test": "node test.js",
        "help": "echo 'Available commands:\n  npm start          - Start web dashboard (production entry)\n  npm run setup     - Interactive setup wizard\n  npm run campaign  - CLI: create and run campaigns\n  npm run cli       - CLI mode (legacy)\n  npm run web:dev   - Web dashboard development mode'"
    },
    "keywords": [
        "scraping",
        "business",
        "leads",
        "b2b",
        "rental-mobil"
    ],
    "author": "Your Name",
    "license": "MIT",
    "dependencies": {
        "@sparticuz/chromium": "^148.0.0",
        "cheerio": "^1.2.0",
        "dotenv": "^17.0.1",
        "express": "^4.18.2",
        "openai": "^4.104.0",
        "puppeteer": "^22.8.2",
        "puppeteer-core": "^24.43.1",
        "sqlite3": "^5.1.6"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    },
    "engines": {
        "node": "20.x"
    },
    "nodemonConfig": {
        "ignore": [
            "output/",
            "node_modules/"
        ]
    }
}
